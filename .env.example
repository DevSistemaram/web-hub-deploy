# URL do backend hub-api — usada pelo proxy do Next.js e pelo serverFetch (server-side apenas)
# Em produção (Vercel): defina como a URL do Cloud Run
API_URL=http://localhost:3000

# URL pública do backend — exposta ao browser (usada no link de documentação e redirecionamentos OAuth)
# Em produção (Vercel): mesma URL do Cloud Run
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
